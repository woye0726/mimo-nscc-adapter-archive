# MiMo-NSCC Copilot Bridge — Environment Variables
#
# Copy this file to .env and fill in your values.
# NOTE: .env files are gitignored; never commit real secrets.
#
# These environment variables are NOT used by the extension at runtime.
# They are provided for CI/CD pipelines and automated testing scenarios
# where interactive SecretStorage input is not available.
#
# For daily use, always prefer the VS Code commands:
#   "MiMo-NSCC: Set MiMo API Key"  → stores in OS keychain
#   "MiMo-NSCC: Set NSCC API Key"  → stores in OS keychain

# MiMo (Xiaomi) API key
# Get one at: https://platform.xiaomimimo.com
# MIMO_API_KEY=sk-your-mimo-api-key-here

# NSCC (国家超算长沙中心) API key
# Get one at: https://maas.nscc-cs.cn
# NSCC_API_KEY=sk-your-nscc-api-key-here
